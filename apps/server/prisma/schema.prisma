generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════
// USER
// ════════════════════════════════════════
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name           String?
  role           Role      @default(CUSTOMER)
  defaultAddress String?   @db.Text
  avatar           String?
  balance           Int       @default(0)
  resetCode         String?
  resetCodeExpires  DateTime?
  showPurchases     Boolean   @default(true)
  showFavorites     Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  cart    Cart?
  orders  Order[]
  seller  Seller?

  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")
  comments         Comment[]
  favorites        Favorite[]
  ratings          Rating[]
  playHistory      PlayHistory[]

  @@map("users")
}

enum Role {
  CUSTOMER
  SELLER
  ADMIN
}

// ════════════════════════════════════════
// SELLER (厂牌/卖家)
// ════════════════════════════════════════
model Seller {
  id           Int          @id @default(autoincrement())
  userId       Int          @unique
  storeName    String
  contactEmail String?
  contactPhone String?
  description  String?      @db.Text
  status       SellerStatus @default(PENDING)
  balance      Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  albums Album[]

  @@map("sellers")
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
}

// ════════════════════════════════════════
// ARTIST (乐队/艺人)
// ════════════════════════════════════════
model Artist {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  photo       String?
  foundedYear Int?
  country     String?
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  albums Album[]

  @@map("artists")
}

// ════════════════════════════════════════
// ALBUM
// ════════════════════════════════════════
model Album {
  id          Int         @id @default(autoincrement())
  artist      String
  artistId    Int?
  title       String
  year        Int?
  label       String?
  country     String?
  price       Int                       // stored in yuan, e.g. 380 = ¥380
  badge       String?
  description String      @db.Text
  coverUrl    String?
  gradient    String?
  color       String?     // dominant color: red/orange/yellow/green/cyan/blue/purple/black/white (9)
  slug        String      @unique
  stock       Int         @default(10)
  status      AlbumStatus @default(ACTIVE)
  sellerId    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  seller       Seller?       @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  artistRel    Artist?       @relation(fields: [artistId], references: [id], onDelete: SetNull)
  tracks       Track[]
  categories   AlbumCategory[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
  comments     Comment[]
  favorites    Favorite[]
  ratings      Rating[]
  playHistory  PlayHistory[]

  @@map("albums")
}

enum AlbumStatus {
  ACTIVE
  DELISTED
}

// ════════════════════════════════════════
// TRACK
// ════════════════════════════════════════
model Track {
  id        Int     @id @default(autoincrement())
  albumId   Int
  title     String
  duration  String?
  position  Int
  isSection Boolean @default(false)
  audioUrl  String?

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  playHistory PlayHistory[]

  @@map("tracks")
}

// ════════════════════════════════════════
// CATEGORY
// ════════════════════════════════════════
model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
  slug String @unique

  albums AlbumCategory[]

  @@map("categories")
}

// ════════════════════════════════════════
// ALBUM ⇄ CATEGORY (many-to-many)
// ════════════════════════════════════════
model AlbumCategory {
  albumId    Int
  categoryId Int

  album    Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([albumId, categoryId])
  @@map("album_categories")
}

// ════════════════════════════════════════
// CART
// ════════════════════════════════════════
model Cart {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id       Int @id @default(autoincrement())
  cartId   Int
  albumId  Int
  quantity Int @default(1)

  cart  Cart  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

// ════════════════════════════════════════
// ORDER
// ════════════════════════════════════════
model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  status          OrderStatus @default(PENDING)
  totalAmount     Int
  shippingAddress String?     @db.Text
  expiresAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        Int              @id @default(autoincrement())
  orderId   Int
  albumId   Int?
  quantity  Int
  unitPrice Int              // snapshot of price at purchase time
  status    OrderItemStatus  @default(ACTIVE)

  order Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  album Album? @relation(fields: [albumId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

enum OrderItemStatus {
  ACTIVE
  SHIPPED
  REFUNDED
}

// ════════════════════════════════════════
// MESSAGE (用户↔商家聊天)
// ════════════════════════════════════════
model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String   @db.Text
  imageUrl   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId])
  @@map("messages")
}

// ════════════════════════════════════════
// COMMENT (专辑评论)
// ════════════════════════════════════════
model Comment {
  id              Int       @id @default(autoincrement())
  albumId         Int
  userId          Int
  parentId        Int?
  replyToUserId   Int?
  replyToUserName String?
  content         String    @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  album   Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")

  @@index([albumId])
  @@index([parentId])
  @@map("comments")
}

// ════════════════════════════════════════
// FAVORITE (收藏)
// ════════════════════════════════════════
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  albumId   Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@map("favorites")
}

// ════════════════════════════════════════
// RATING (专辑评分)
// ════════════════════════════════════════
model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int
  albumId   Int
  score     Int      // 1-5 星
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@map("ratings")
}

// ════════════════════════════════════════
// PLAY HISTORY (播放历史)
// ════════════════════════════════════════
model PlayHistory {
  id       Int      @id @default(autoincrement())
  userId   Int
  trackId  Int
  albumId  Int
  playedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt])
  @@map("play_history")
}
